# ---------------------------------------------------------------------------
# Crypto instance — env-file for the platform's Lightdash stack.
# This is the DOMAIN policy (project name, which dbt project to publish). The
# generic stack lives in the platform repo (deploy/); only the knobs that make
# it "crypto" live here, per the platform/instance boundary in AGENTS.md.
#
# Run from the platform repo root:
#   cp instances/crypto/deploy/.env.example instances/crypto/deploy/.env
#   docker compose -f deploy/docker-compose.yml \
#     --env-file instances/crypto/deploy/.env --profile setup run --rm lightdash-init
# ---------------------------------------------------------------------------

# --- ClickHouse (warehouse) -------------------------------------------------
CH_HOST=clickhouse
CLICKHOUSE_DB=norn
CLICKHOUSE_USER=norn
CLICKHOUSE_PASSWORD=norn

# --- Lightdash server -------------------------------------------------------
LIGHTDASH_SECRET=local-dev-secret
SITE_URL=http://localhost:8080

# --- Bootstrap / project ----------------------------------------------------
LD_ADMIN_EMAIL=admin@norn.local
LD_ADMIN_PASSWORD=norn-admin-pw1
LD_ADMIN_FIRST_NAME=Norn
LD_ADMIN_LAST_NAME=Admin
LD_ORG_NAME=Norn

# The crypto project + its dbt models. Path is relative to deploy/ (the compose
# file's directory).
LD_PROJECT_NAME=norn-ett
DBT_PROJECT_HOST_DIR=../instances/ett/dbt
